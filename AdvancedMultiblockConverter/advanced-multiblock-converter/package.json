{
  "name": "advanced-multiblock-converter",
  "version": "1.0.0",
  "description": "Tool to create GTCEU multiblock structures from Building Gadgets JSON's",
  "author": "Redeix @TerraFirmaGreg",
  "main": "main.js",
  "scripts": {
    "dev": "cross-env VITE_DEV_SERVER_URL=http://localhost:5173 concurrently \"vite\" \"electron .\"",
    "build": "vite build",
    "start": "electron .",
    "dist": "electron-builder"
  },
  "dependencies": {
    "prismjs": "^1.30.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-syntax-highlighter": "^15.6.6"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "@babel/core": "^7.22.0",
    "@babel/preset-react": "^7.22.0",
    "@vitejs/plugin-react": "^5.0.3",
    "babel-loader": "^9.1.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "electron-builder": "^26.0.12",
    "vite": "^7.1.6",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.4"
  },
  "build": {
    "appId": "com.yourname.advancedmultiblockconverter",
    "productName": "Advanced Multiblock Converter",
    "files": [
      "dist/**",
      "main.js",
      "preload.js",
      "input.json",
      "output.js",
      "MultiConverter.js",
      "runConversion.js",
      "package.json"
    ],
  "directories": {
    "output": "."
  },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": ["deb", "AppImage"]
    },
    "mac": {
      "target": "dmg"
    },
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "icon": "assets/icon.ico"
  }
}
